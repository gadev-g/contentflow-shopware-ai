<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="ContentFlow\ShopwareAi\Service\ContentFlowClient">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="http_client"/>
        </service>
        <service id="ContentFlow\ShopwareAi\Controller\ContentFlowController" public="true">
            <argument type="service" id="ContentFlow\ShopwareAi\Service\ContentFlowClient"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="ContentFlow\ShopwareAi\Service\SearchCatalogSynchronizer"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>
        <service id="ContentFlow\ShopwareAi\Service\ContentFlowSearchBuilder"
                 decorates="Shopware\Core\Content\Product\SearchKeyword\ProductSearchBuilderInterface">
            <argument type="service" id="ContentFlow\ShopwareAi\Service\ContentFlowSearchBuilder.inner"/>
            <argument type="service" id="ContentFlow\ShopwareAi\Service\ContentFlowClient"/>
            <argument type="service" id="logger"/>
        </service>
        <service id="ContentFlow\ShopwareAi\Controller\SearchStorefrontController" public="true">
            <argument type="service" id="ContentFlow\ShopwareAi\Service\ContentFlowClient"/>
            <argument type="service" id="Shopware\Core\Checkout\Cart\SalesChannel\CartService"/>
            <argument type="service" id="Shopware\Core\Checkout\Cart\LineItemFactoryHandler\ProductLineItemFactory"/>
            <argument type="service" id="sales_channel.product.repository"/>
        </service>
        <service id="ContentFlow\ShopwareAi\Service\SearchCatalogSynchronizer">
            <argument type="service" id="ContentFlow\ShopwareAi\Service\ContentFlowClient"/>
            <argument type="service" id="product.repository"/>
        </service>
        <service id="ContentFlow\ShopwareAi\Subscriber\ProductSearchIndexSubscriber">
            <argument type="service" id="messenger.default_bus"/>
            <tag name="kernel.event_subscriber"/>
        </service>
        <service id="ContentFlow\ShopwareAi\Message\SearchCatalogSyncHandler">
            <argument type="service" id="ContentFlow\ShopwareAi\Service\SearchCatalogSynchronizer"/>
            <tag name="messenger.message_handler"/>
        </service>
        <service id="ContentFlow\ShopwareAi\ScheduledTask\SearchCatalogReconcileTask">
            <tag name="shopware.scheduled.task"/>
        </service>
        <service id="ContentFlow\ShopwareAi\ScheduledTask\SearchCatalogReconcileTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="ContentFlow\ShopwareAi\Service\SearchCatalogSynchronizer"/>
            <tag name="messenger.message_handler"/>
        </service>
    </services>
</container>
