<sw-page class="contentflow-page">
    <template #smart-bar-header>
        <h2>ContentFlow</h2>
    </template>

    <template #content>
        <div class="contentflow-shell">
            <section class="contentflow-hero">
                <div class="contentflow-icon">✦</div>
                <div>
                    <span class="contentflow-eyebrow">SHOPWARE AI WORKFLOW</span>
                    <h1>Produktinhalte sicher übersetzen</h1>
                    <p>Produkte auswählen, Vorschau prüfen und erst nach der Freigabe in Shopware speichern.</p>
                </div>
            </section>

            <sw-card title="ContentFlow-Einstellungen" position-identifier="contentflow-settings">
                <div class="contentflow-settings-row">
                    <mt-select
                        v-model="provider"
                        label="Standard-Provider"
                        placeholder="Verfügbaren Provider auswählen"
                        :options="providerOptions"
                        :disabled="providersLoading || providerOptions.length === 0" />
                    <sw-button-process
                        variant="primary"
                        :is-loading="providerSaving"
                        :disabled="!provider || providersLoading || providerSaving"
                        @click="saveProvider">
                        Provider speichern
                    </sw-button-process>
                </div>
                <p class="contentflow-field-hint">Es werden nur Provider angezeigt, die für das verbundene ContentFlow-Projekt aktiviert sind.</p>
            </sw-card>

            <sw-card title="1. Produkte und Sprachen auswählen" position-identifier="contentflow-selection">
                <sw-entity-multi-select
                    v-model:entity-collection="selectedProducts"
                    entity-name="product"
                    :criteria="productCriteria"
                    label-property="name"
                    placeholder="Produkte auswählen" />
                <p class="contentflow-field-hint">Es werden die vorhandenen Hauptprodukte angezeigt. Varianten werden über ihr Hauptprodukt verarbeitet.</p>

                <div class="contentflow-language-grid">
                    <sw-entity-single-select
                        v-model:value="sourceLanguageId"
                        entity="language"
                        label="Ausgangssprache"
                        placeholder="Shopware-Sprache auswählen"
                        :disabled="languagesLoading" />
                    <sw-entity-single-select
                        v-model:value="targetLanguageId"
                        entity="language"
                        label="Zielsprache"
                        placeholder="Shopware-Sprache auswählen"
                        :disabled="languagesLoading" />
                </div>

                <sw-button-process
                    variant="primary"
                    :is-loading="loading"
                    :disabled="selectedProducts.length === 0 || !sourceLanguageId || !targetLanguageId || loading"
                    @click="createPreview">
                    Übersetzungsvorschau erstellen
                </sw-button-process>
            </sw-card>

            <sw-card v-if="preview" title="2. Vorschau prüfen und freigeben" position-identifier="contentflow-preview">
                <div v-for="record in preview.records" :key="record.reference" class="contentflow-preview-record">
                    <strong>{{ record.reference }}</strong>
                    <dl>
                        <template v-for="(value, field) in record.fields" :key="field">
                            <dt>{{ field }}</dt>
                            <dd>{{ value }}</dd>
                        </template>
                    </dl>
                </div>

                <sw-button-process
                    variant="primary"
                    :is-loading="saving"
                    :disabled="!targetLanguageId || saving"
                    @click="approve">
                    Freigeben und speichern
                </sw-button-process>
            </sw-card>

            <sw-card class="contentflow-coverage-card" position-identifier="contentflow-coverage">
                <template #title>
                    <div class="contentflow-product-header">
                        <div class="contentflow-product-icon contentflow-product-icon--coverage">
                            <mt-icon name="regular-chart-bar" size="24px" />
                        </div>
                        <div class="contentflow-product-copy">
                            <div class="contentflow-product-kicker"><span>CONTENT COVERAGE</span></div>
                            <h2>Pflegestatus deines Produktkatalogs</h2>
                        </div>
                    </div>
                </template>

                <p class="contentflow-product-description">Erkenne für die gewählte Zielsprache sofort, welche Produkte übersetzt und SEO-fertig sind und welchen Bildern noch Alt-Texte fehlen.</p>

                <div v-if="coverage" class="contentflow-coverage-grid">
                    <article>
                        <div><span>Übersetzte Produkte</span><strong>{{ coverage.products.translated }} / {{ coverage.products.total }}</strong></div>
                        <div class="contentflow-coverage-progress"><span :style="{ width: coverageRate(coverage.products.translated, coverage.products.total) + '%' }"></span></div>
                        <small>{{ coverageRate(coverage.products.translated, coverage.products.total) }} % vollständig</small>
                    </article>
                    <article>
                        <div><span>SEO vollständig</span><strong>{{ coverage.products.seo_complete }} / {{ coverage.products.total }}</strong></div>
                        <div class="contentflow-coverage-progress"><span :style="{ width: coverageRate(coverage.products.seo_complete, coverage.products.total) + '%' }"></span></div>
                        <small>{{ coverageRate(coverage.products.seo_complete, coverage.products.total) }} % vollständig</small>
                    </article>
                    <article>
                        <div><span>Bilder mit Alt-Text</span><strong>{{ coverage.media.with_alt }} / {{ coverage.media.total }}</strong></div>
                        <div class="contentflow-coverage-progress"><span :style="{ width: coverageRate(coverage.media.with_alt, coverage.media.total) + '%' }"></span></div>
                        <small>{{ coverageRate(coverage.media.with_alt, coverage.media.total) }} % barriereärmer</small>
                    </article>
                </div>

                <div v-if="coverage && coverage.missing.length" class="contentflow-coverage-missing">
                    <h3>Als Nächstes bearbeiten</h3>
                    <div v-for="product in coverage.missing" :key="product.id">
                        <div><strong>{{ product.name || product.product_number }}</strong><span>{{ product.product_number }}</span></div>
                        <span v-if="!Number(product.translated)" class="is-warning">Übersetzung fehlt</span>
                        <span v-if="!Number(product.seo_complete)" class="is-info">SEO unvollständig</span>
                    </div>
                </div>
                <div v-else-if="coverageLoading" class="contentflow-coverage-loading">Abdeckung wird berechnet …</div>
            </sw-card>

            <sw-card class="contentflow-seo-card" position-identifier="contentflow-seo">
                <template #title>
                    <div class="contentflow-product-header">
                        <div class="contentflow-product-icon contentflow-product-icon--seo">
                            <mt-icon name="regular-search" size="24px" />
                        </div>
                        <div class="contentflow-product-copy">
                            <div class="contentflow-product-kicker">
                                <span>SEO INTELLIGENCE</span>
                            </div>
                            <h2>Mehr Sichtbarkeit für deine Produkte</h2>
                        </div>
                    </div>
                </template>
                <template #headerRight>
                    <span class="contentflow-product-badge">STARTER PRODUCT</span>
                </template>

                <p class="contentflow-product-description">ContentFlow analysiert die ausgewählten Produktdaten und erstellt suchmaschinenfertige Metadaten zur kontrollierten Freigabe.</p>

                <div class="contentflow-feature-grid">
                    <div class="contentflow-feature">
                        <mt-icon name="regular-file-text" size="20px" />
                        <div><strong>Meta-Daten</strong><span>SEO-Titel und Beschreibungen</span></div>
                    </div>
                    <div class="contentflow-feature">
                        <mt-icon name="regular-search" size="20px" />
                        <div><strong>Keywords</strong><span>Passend zu Produkt und Sprache</span></div>
                    </div>
                    <div class="contentflow-feature">
                        <mt-icon name="regular-code" size="20px" />
                        <div><strong>Schema.org</strong><span>Strukturierte JSON-LD-Daten</span></div>
                    </div>
                </div>

                <sw-button-process
                    class="contentflow-seo-action"
                    variant="primary"
                    :is-loading="seoLoading"
                    :disabled="selectedProducts.length === 0 || seoLoading"
                    @click="createSeoPreview">
                    SEO-Vorschau erstellen
                </sw-button-process>

                <div v-if="seoPreview" class="contentflow-seo-preview">
                    <article v-for="record in seoPreview.records" :key="record.reference" class="contentflow-preview-record">
                        <div class="contentflow-preview-heading">
                            <span class="contentflow-preview-status"><mt-icon name="regular-check-circle" size="16px" /> Vorschau bereit</span>
                            <strong>{{ record.reference }}</strong>
                        </div>
                        <div class="contentflow-seo-field">
                            <span>SEO-Titel</span>
                            <h3>{{ record.metadata.seo_title }}</h3>
                        </div>
                        <div class="contentflow-seo-field">
                            <span>Meta-Beschreibung</span>
                            <p>{{ record.metadata.meta_description }}</p>
                        </div>
                        <div class="contentflow-seo-field">
                            <span>Schema.org JSON-LD</span>
                            <code>{{ formatSchema(record.metadata.schema_org) }}</code>
                        </div>
                    </article>
                    <sw-button-process
                        variant="primary"
                        :is-loading="saving"
                        :disabled="!targetLanguageId || saving"
                        @click="approveSeo">
                        SEO-Daten freigeben und speichern
                    </sw-button-process>
                </div>
            </sw-card>

            <sw-card class="contentflow-search-card" position-identifier="contentflow-search">
                <template #title>
                    <div class="contentflow-product-header">
                        <div class="contentflow-product-icon contentflow-product-icon--search">
                            <mt-icon name="regular-search" size="24px" />
                        </div>
                        <div class="contentflow-product-copy">
                            <div class="contentflow-product-kicker"><span>CONTENTFLOW AI SEARCH</span></div>
                            <h2>Suche verstehen, steuern und verkaufen</h2>
                        </div>
                    </div>
                </template>
                <template #headerRight><span class="contentflow-product-badge">PRO PRODUCT</span></template>

                <p class="contentflow-product-description">Semantische Produktsuche mit verbindlichen Händlerregeln, Nulltrefferanalyse und sicherem Shopware-Fallback.</p>

                <div v-if="searchAnalytics" class="contentflow-search-stats">
                    <div><strong>{{ searchAnalytics.totals.searches || 0 }}</strong><span>Suchanfragen</span></div>
                    <div><strong>{{ searchAnalytics.totals.zero_results || 0 }}</strong><span>Nulltreffer</span></div>
                    <div><strong>{{ searchAnalytics.totals.clicks || 0 }}</strong><span>Klicks</span></div>
                    <div><strong>{{ searchAnalytics.totals.carts || 0 }}</strong><span>Warenkörbe</span></div>
                    <div><strong>{{ searchAnalytics.totals.purchases || 0 }}</strong><span>Käufe</span></div>
                </div>

                <div class="contentflow-search-actions">
                    <sw-button-process variant="primary" :is-loading="searchSyncing" @click="syncSearchCatalog">Produktindex synchronisieren</sw-button-process>
                    <span v-if="searchAnalytics && !searchAnalytics.active" class="contentflow-search-upgrade">Die aktive KI-Suche benötigt den Professional-Tarif.</span>
                </div>

                <section class="contentflow-ranking-section">
                    <div class="contentflow-ranking-heading">
                        <h3>Ranking testen</h3>
                        <p>Prüfe, welche Produkte ContentFlow für eine konkrete Kundenanfrage priorisiert und warum.</p>
                    </div>
                    <div class="contentflow-search-test">
                        <sw-text-field v-model:value="searchQuery" placeholder="z. B. leichte Jacke für Regen" />
                        <sw-button-process variant="primary" :is-loading="searchLoading" :disabled="!searchQuery || searchLoading" @click="testAiSearch">Suche testen</sw-button-process>
                    </div>
                <div v-if="searchTest" class="contentflow-ranking-summary">
                    <strong>{{ searchTest.candidates.length }} passende Produkte</strong>
                    <span>Die Reihenfolge kombiniert Texttreffer, Shopware-Relevanz, Händlerregeln und bisherige Nutzersignale.</span>
                </div>
                <ol v-if="searchTest && searchTest.candidates.length" class="contentflow-ranking-list">
                    <li v-for="candidate in searchTest.candidates" :key="candidate.id">
                        <span class="contentflow-ranking-position">{{ searchTest.candidates.indexOf(candidate) + 1 }}</span>
                        <div class="contentflow-ranking-product">
                            <strong>{{ candidate.title || candidate.id }}</strong>
                            <span v-if="candidate.manufacturer || candidate.product_number">{{ candidate.manufacturer }}<template v-if="candidate.manufacturer && candidate.product_number"> · </template>{{ candidate.product_number }}</span>
                        </div>
                        <div class="contentflow-ranking-score"><strong>{{ candidate.score }}</strong><span>Ranking-Punkte</span></div>
                        <div class="contentflow-ranking-reasons">
                            <span v-for="reason in candidate.reasons" :key="reason">{{ rankingReasonLabel(reason) }}</span>
                            <small>{{ candidate.matched_tokens || 0 }} von {{ candidate.total_tokens || 0 }} Suchbegriffen erkannt</small>
                        </div>
                    </li>
                </ol>
                <div v-else-if="searchTest" class="contentflow-ranking-empty">Keine passenden Produkte gefunden. Synchronisiere den Produktindex oder ergänze Synonyme für diese Suchanfrage.</div>
                </section>

                <div class="contentflow-rule-editor">
                    <div v-if="searchAnalytics && searchAnalytics.rules.length" class="contentflow-rule-list">
                        <div class="contentflow-rule-list-heading">
                            <div><h3>Bestehende Händlerregeln</h3><p>Bearbeite Priorisierungen, Ausschlüsse und Synonyme für deine Suche.</p></div>
                            <span>{{ searchAnalytics.rules.length }} Regeln</span>
                        </div>
                        <article v-for="rule in searchAnalytics.rules" :key="rule.id" class="contentflow-rule-item">
                            <div>
                                <strong>{{ rule.name }}</strong>
                                <span>{{ rule.query_pattern }}</span>
                            </div>
                            <span class="contentflow-rule-type">{{ rule.rule_type }}</span>
                            <div class="contentflow-rule-actions">
                                <sw-button size="small" @click="editSearchRule(rule)">Bearbeiten</sw-button>
                                <sw-button size="small" variant="danger" @click="deleteSearchRule(rule)">Löschen</sw-button>
                            </div>
                        </article>
                    </div>

                    <div class="contentflow-rule-form-heading">
                        <h3>{{ searchRule.id ? 'Händlerregel bearbeiten' : 'Neue Händlerregel' }}</h3>
                        <sw-button v-if="searchRule.id" size="small" @click="resetSearchRule">Abbrechen</sw-button>
                    </div>
                    <div class="contentflow-rule-grid">
                        <sw-text-field v-model:value="searchRule.name" label="Name" />
                        <mt-select v-model="searchRule.type" label="Regeltyp" :options="[
                            { value: 'pin', label: 'Produkte anheften' },
                            { value: 'boost', label: 'Produkte boosten' },
                            { value: 'exclude', label: 'Produkte ausschließen' },
                            { value: 'synonym', label: 'Synonyme' }
                        ]" />
                        <sw-text-field v-model:value="searchRule.query" label="Suchbegriff" />
                        <sw-text-field
                            v-if="searchRule.type === 'synonym'"
                            v-model:value="searchRuleSynonyms"
                            label="Synonyme"
                            help-text="Mehrere Begriffe mit Komma trennen"
                        />
                        <sw-entity-multi-select
                            v-else
                            v-model:entity-collection="selectedRuleProducts"
                            entity-name="product"
                            label="Produkte"
                            label-property="name"
                            :criteria="productCriteria"
                            placeholder="Produkte auswählen"
                        />
                    </div>
                    <sw-button variant="primary" :disabled="!searchRule.name || !searchRule.query" @click="saveSearchRule">{{ searchRule.id ? 'Änderungen speichern' : 'Regel speichern' }}</sw-button>
                </div>

                <div v-if="searchAnalytics && searchAnalytics.queries.length" class="contentflow-query-table">
                    <div class="contentflow-query-heading"><div><h3>Suchanfragen der letzten 30 Tage</h3><p>Erkenne Nulltreffer und Begriffe mit ungenutztem Verkaufspotenzial.</p></div></div>
                    <div class="contentflow-query-header" aria-hidden="true">
                        <span>Suchanfrage</span>
                        <span>Status</span>
                        <span>Suchen</span>
                        <span>Treffer</span>
                        <span>Klicks</span>
                        <span>Warenkörbe</span>
                    </div>
                    <div v-for="row in searchAnalytics.queries" :key="row.query" class="contentflow-query-row">
                        <div class="contentflow-query-name"><strong>{{ row.query }}</strong></div>
                        <div class="contentflow-query-status-column"><span :class="['contentflow-query-status', { 'is-warning': !row.result_count }]">{{ row.result_count ? 'Treffer vorhanden' : 'Nulltreffer' }}</span></div>
                        <div class="contentflow-query-metric"><strong>{{ row.searches }}</strong></div>
                        <div class="contentflow-query-metric"><strong>{{ row.result_count }}</strong></div>
                        <div class="contentflow-query-metric"><strong>{{ row.clicks }} <small>{{ queryRate(row.clicks, row.searches) }}</small></strong></div>
                        <div class="contentflow-query-metric"><strong>{{ row.carts }} <small>{{ queryRate(row.carts, row.searches) }}</small></strong></div>
                    </div>
                </div>
            </sw-card>
        </div>
    </template>
</sw-page>
