{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_body_inner %}
    {{ parent() }}
    {% if config('ContentFlowShopwareAi.config.assistantEnabled') %}
        <div class="contentflow-assistant" data-contentflow-assistant>
            <button class="contentflow-assistant__toggle" type="button" aria-expanded="false">
                <span class="contentflow-assistant__toggle-icon-wrap" aria-hidden="true">
                    <svg class="contentflow-assistant__toggle-icon" viewBox="0 0 24 24">
                        <path d="M12 2.5 13.8 7a5 5 0 0 0 2.8 2.8l4.5 1.8-4.5 1.8a5 5 0 0 0-2.8 2.8L12 20.7l-1.8-4.5a5 5 0 0 0-2.8-2.8l-4.5-1.8 4.5-1.8A5 5 0 0 0 10.2 7L12 2.5Z"/>
                        <path d="m19 2 .7 1.8a2 2 0 0 0 1.1 1.1l1.8.7-1.8.7a2 2 0 0 0-1.1 1.1L19 9.2l-.7-1.8a2 2 0 0 0-1.1-1.1l-1.8-.7 1.8-.7a2 2 0 0 0 1.1-1.1L19 2Z"/>
                    </svg>
                </span>
                <span>KI-Berater</span>
            </button>
            <section class="contentflow-assistant__panel" hidden>
                <header class="contentflow-assistant__header">
                    <strong class="contentflow-assistant__title">
                        <span class="contentflow-assistant__title-badge" aria-hidden="true">
                            <svg class="contentflow-assistant__title-icon" viewBox="0 0 24 24">
                                <path d="M12 2.5 13.8 7a5 5 0 0 0 2.8 2.8l4.5 1.8-4.5 1.8a5 5 0 0 0-2.8 2.8L12 20.7l-1.8-4.5a5 5 0 0 0-2.8-2.8l-4.5-1.8 4.5-1.8A5 5 0 0 0 10.2 7L12 2.5Z"/>
                                <path d="m19 2 .7 1.8a2 2 0 0 0 1.1 1.1l1.8.7-1.8.7a2 2 0 0 0-1.1 1.1L19 9.2l-.7-1.8a2 2 0 0 0-1.1-1.1l-1.8-.7 1.8-.7a2 2 0 0 0 1.1-1.1L19 2Z"/>
                            </svg>
                        </span>
                        <span>ContentFlow Einkaufsberater</span>
                    </strong>
                    <span class="contentflow-assistant__header-actions">
                        <button type="button" data-contentflow-expand aria-label="Auf Vollbild vergrößern" aria-pressed="false">
                            <img src="{{ asset('bundles/contentflowshopwareai/storefront/img/contentflow-expand.png') }}"
                                 alt=""
                                 aria-hidden="true">
                        </button>
                        <button type="button" data-contentflow-close aria-label="Schließen">×</button>
                    </span>
                </header>
                <div class="contentflow-assistant__messages" aria-live="polite"></div>
                <form><input name="message" placeholder="Was suchst du?" required><button type="submit">Senden</button></form>
            </section>
        </div>
    {% endif %}
{% endblock %}
